# ============================================================
# CharchaGram — Environment Variables
# ============================================================
# Copy this file to .env (or to apps/backend/.env) and fill in real values.
# NEVER commit .env files — they are in .gitignore.
# ============================================================

# ── Backend (apps/backend/.env) ──────────────────────────────────────────────

# MongoDB Atlas connection string (required)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?retryWrites=true&w=majority
MONGO_URI=

# JWT secret — use a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=

# Port the Express server listens on (default: 3000)
PORT=3000

# Application environment: development | production | test
NODE_ENV=development

# Frontend origin allowed by CORS (e.g. http://localhost:3001 for local dev)
FRONTEND_DEPLOY_URL=http://localhost:3001

# MSG91 OTP service credentials (for phone-based authentication)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# Brevo (Sendinblue) transactional email
BREVO_API_KEY=

# AWS S3 / DigitalOcean Spaces (for MongoDB backup script)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=

# ── Frontend (apps/frontend/.env.local) ──────────────────────────────────────

# Public URL of the backend API (must start with NEXT_PUBLIC_ to be exposed to the browser)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Google Analytics measurement ID
NEXT_PUBLIC_GA_ID=
